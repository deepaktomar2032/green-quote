# The port the NestJS server listens on.
# Example: 3000
PORT=

# Prisma connection string for the database.
# For SQLite (local dev), the path is relative to the prisma/ directory.
# Example: file:./dev.db
DATABASE_URL=

# Secret key used to sign & verify JWT tokens.
# Must be a long, random, unpredictable string.
JWT_SECRET=

# How long a JWT token stays valid before it expires.
# Accepts ms-compatible duration strings: 7d, 1d.
# Example: 7d
JWT_EXPIRES_IN=

# Name of this service as it appears in OpenTelemetry logs, traces & metrics.
# Example: green-quote-api
OTEL_SERVICE_NAME=

# OTLP gRPC endpoint where traces & metrics are sent (Aspire Dashboard collector).
# In Docker Compose this is overridden to the internal address: http://aspire:18889
# In production point to your collector host.
# Example: http://aspire:18889
OTEL_EXPORTER_OTLP_ENDPOINT=

# Set to "true" to enable CORS. Required when the client runs on a different
# origin than the server (e.g. separate frontend dev server or deployed domain). 
# Example: true
ENABLE_CORS=

# The URL of the frontend client. Only used when ENABLE_CORS=true.
# Must match the exact origin (protocol + host + port) of the client app.
# Example: http://localhost:5173
CLIENT_URL=